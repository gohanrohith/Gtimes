<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('../partials/nav') %>
<div class="gt-page-hero">
  <div class="container">
    <h1>Events</h1>
    <p>Upcoming and recent events from Greenwood campuses</p>
  </div>
</div>
<main class="section">
  <div class="container">
    <% if (typeof campuses !== 'undefined' && campuses.length > 0) { %>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem;align-items:center">
      <a href="/events" class="btn btn-sm <%= !activeCampus ? 'btn-primary' : 'btn-outline' %>">All Campuses</a>
      <% campuses.forEach(c => { %>
      <a href="/events?campus=<%= encodeURIComponent(c) %>" class="btn btn-sm <%= activeCampus===c ? 'btn-primary' : 'btn-outline' %>"><%= c %></a>
      <% }) %>
    </div>
    <% } %>
    <% if (upcoming && upcoming.length > 0) { %>
    <div class="gt-section-header"><h2>Upcoming Events</h2></div>
    <div class="gt-events-grid" style="margin-bottom:3rem">
      <% upcoming.forEach(ev => { %>
      <div class="gt-event-card">
        <div class="gt-event-cover">
          <% if (ev.cover_image) { %><img src="/uploads/events/<%= ev.cover_image %>" alt="<%= ev.title %>"><% } else { %><div class="gt-event-cover-placeholder"><i class="fas fa-calendar-star"></i></div><% } %>
        </div>
        <div class="gt-event-card-body">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem">
            <div class="gt-event-card-date"><i class="fas fa-calendar-alt"></i> <%= ev.event_date ? new Date(ev.event_date).toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'long',year:'numeric'}) : 'Date TBA' %></div>
            <span class="gt-event-badge <%= ev.status %>"><%= ev.status %></span>
          </div>
          <h3><%= ev.title %></h3>
          <% if (ev.description) { %><p><%= ev.description.substring(0,120) %><%= ev.description.length>120?'…':'' %></p><% } %>
          <% if (ev.location) { %><p style="font-size:.8rem;color:var(--gt-gray);margin-top:.5rem"><i class="fas fa-map-marker-alt"></i> <%= ev.location %></p><% } %>
          <% if (ev.event_time) { %><p style="font-size:.8rem;color:var(--gt-gray)"><i class="fas fa-clock"></i> <%= ev.event_time %></p><% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (past && past.length > 0) { %>
    <div class="gt-section-header"><h2>Past Events</h2></div>
    <div class="gt-events-grid">
      <% past.forEach(ev => { %>
      <div class="gt-event-card" style="opacity:.8">
        <div class="gt-event-cover">
          <% if (ev.cover_image) { %><img src="/uploads/events/<%= ev.cover_image %>" alt="<%= ev.title %>"><% } else { %><div class="gt-event-cover-placeholder"><i class="fas fa-calendar-check"></i></div><% } %>
        </div>
        <div class="gt-event-card-body">
          <div class="gt-event-card-date"><%= ev.event_date ? new Date(ev.event_date).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) : 'Completed' %></div>
          <h3><%= ev.title %></h3>
          <% if (ev.location) { %><p style="font-size:.8rem;color:var(--gt-gray)"><i class="fas fa-map-marker-alt"></i> <%= ev.location %></p><% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if ((!upcoming || !upcoming.length) && (!past || !past.length)) { %>
    <div class="gt-empty"><i class="fas fa-calendar-alt"></i><p>No events listed yet.</p></div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>

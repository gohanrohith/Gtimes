<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('../partials/nav') %>
<div class="gt-page-hero">
  <div class="container">
    <h1><%= activeYear ? activeYear + ' Archive' : 'All News' %></h1>
    <p><%= activeYear ? 'Stories published in ' + activeYear : 'Latest stories from Greenwood schools and beyond' %></p>
  </div>
</div>
<main class="section">
  <div class="container">
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;align-items:center">
      <a href="/articles" class="btn btn-sm <%= !activeYear ? 'btn-primary' : 'btn-outline' %>">All</a>
      <% if (typeof categories !== 'undefined') { categories.forEach(c => { %>
      <a href="/category/<%= c.slug %>" class="btn btn-sm btn-outline" style="border-color:<%= c.color %>;color:<%= c.color %>"><%= c.name %></a>
      <% }) } %>
    </div>
    <% if (typeof availableYears !== 'undefined' && availableYears.length > 0) { %>
    <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:2rem;align-items:center">
      <span style="font-size:.78rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-right:.25rem">Archive:</span>
      <% availableYears.forEach(y => { %>
      <a href="/articles?year=<%= y.yr %>" class="gt-year-pill<%= activeYear == y.yr ? ' active' : '' %>"><%= y.yr %> <span class="gt-year-count"><%= y.cnt %></span></a>
      <% }) %>
    </div>
    <% } %>
    <% if (articles && articles.length > 0) { %>
    <div class="gt-articles-grid">
      <% articles.forEach(a => { %>
      <a href="/article/<%= a.slug %>" class="gt-article-card" style="text-decoration:none">
        <div class="gt-card-image">
          <% if (a.cover_image) { %><img src="/uploads/articles/<%= a.cover_image %>" alt="<%= a.title %>" loading="lazy" onerror="this.style.display='none'"><% } %><div style="<%= a.cover_image ? 'display:none;' : '' %>height:100%;display:flex;align-items:center;justify-content:center;background:var(--gt-off)"><i class="fas fa-newspaper" style="font-size:2rem;color:#ccc"></i></div>
        </div>
        <div class="gt-card-body">
          <div class="gt-card-meta">
            <% if (a.cat_name) { %><span class="gt-cat-badge" style="background:<%= a.cat_color||'#e63946' %>"><%= a.cat_name %></span><% } %>
            <span class="gt-card-date"><%= new Date(a.published_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
          </div>
          <h3><%= a.title %></h3>
          <p><%= (a.excerpt||'').substring(0,100) %><%= (a.excerpt||'').length>100?'…':'' %></p>
        </div>
        <div class="gt-card-footer">
          <span class="gt-read-more">Read More <i class="fas fa-arrow-right"></i></span>
          <span class="gt-views"><i class="fas fa-clock"></i> <%= a.reading_time %> min &nbsp;<i class="fas fa-eye"></i> <%= a.views %></span>
        </div>
      </a>
      <% }) %>
    </div>
    <% if (pagination.totalPages > 1) { %>
    <div class="gt-pagination">
      <% const yearQ = activeYear ? '&year=' + activeYear : ''; %>
      <% if (pagination.page > 1) { %><a href="/articles?page=<%= pagination.page-1 %><%= yearQ %>">&laquo; Prev</a><% } %>
      <% for (let i=1; i<=pagination.totalPages; i++) { %>
      <% if (i===pagination.page) { %><span class="active"><%= i %></span><% } else { %><a href="/articles?page=<%= i %><%= yearQ %>"><%= i %></a><% } %>
      <% } %>
      <% if (pagination.page < pagination.totalPages) { %><a href="/articles?page=<%= pagination.page+1 %><%= yearQ %>">Next &raquo;</a><% } %>
    </div>
    <% } %>
    <% } else { %>
    <div class="gt-empty"><i class="fas fa-newspaper"></i><p>No articles<%= activeYear ? ' from ' + activeYear : '' %> yet.</p></div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>

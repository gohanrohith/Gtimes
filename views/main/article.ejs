<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <meta name="description" content="<%= (article.excerpt||'').substring(0,160) %>">
  <link rel="canonical" href="<%= canonicalUrl %>">

  <!-- Open Graph -->
  <meta property="og:type"        content="article">
  <meta property="og:title"       content="<%= article.title %>">
  <meta property="og:description" content="<%= (article.excerpt||'').substring(0,200) %>">
  <meta property="og:url"         content="<%= canonicalUrl %>">
  <meta property="og:site_name"   content="<%= settings?.site_name || 'GTimes' %>">
  <% if (article.cover_image) { %>
  <meta property="og:image"       content="<%= domain %>/uploads/articles/<%= article.cover_image %>">
  <% } %>
  <meta property="article:published_time" content="<%= new Date(article.published_at).toISOString() %>">
  <% if (article.cat_name) { %><meta property="article:section" content="<%= article.cat_name %>"><% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= article.title %>">
  <meta name="twitter:description" content="<%= (article.excerpt||'').substring(0,200) %>">
  <% if (article.cover_image) { %>
  <meta name="twitter:image"       content="<%= domain %>/uploads/articles/<%= article.cover_image %>">
  <% } %>

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": "<%= article.title.replace(/"/g, '\\"') %>",
    "description": "<%= (article.excerpt||'').substring(0,200).replace(/"/g, '\\"') %>",
    "datePublished": "<%= new Date(article.published_at).toISOString() %>",
    "dateModified": "<%= new Date(article.updated_at || article.published_at).toISOString() %>",
    "author": { "@type": "Person", "name": "<%= article.author_name %>" },
    "publisher": {
      "@type": "Organization",
      "name": "<%= settings?.site_name || 'GTimes' %>",
      "url": "<%= domain %>"
    }<% if (article.cover_image) { %>,
    "image": "<%= domain %>/uploads/articles/<%= article.cover_image %>"<% } %>
  }
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    #gt-progress-bar { position:fixed;top:0;left:0;height:3px;background:var(--gt-green,#00663A);z-index:9999;width:0%;transition:width .1s linear; }
  </style>
  <style>
    .gt-lang-btn {
      padding:.3rem .85rem; border:1.5px solid var(--gt-green,#00663A); border-radius:20px;
      background:transparent; color:var(--gt-green,#00663A); font-family:inherit;
      font-size:.78rem; font-weight:600; cursor:pointer; transition:background .15s,color .15s;
    }
    .gt-lang-btn:hover { background:var(--gt-green,#00663A); color:#fff; }
    .gt-lang-btn.active { background:var(--gt-green,#00663A); color:#fff; }
    .gt-share-btn {
      display:inline-flex; align-items:center; gap:.4rem; padding:.4rem .9rem;
      border-radius:20px; font-size:.8rem; font-weight:600; text-decoration:none;
      cursor:pointer; border:none; font-family:inherit; transition:opacity .15s;
    }
    .gt-share-btn:hover { opacity:.85; }
    .gt-tag-link {
      display:inline-block; padding:.25rem .7rem; border-radius:20px;
      background:var(--gt-off,#f5f5f5); color:var(--gt-gray-dk,#555);
      font-size:.78rem; font-weight:600; text-decoration:none;
      border:1px solid var(--gt-light,#e0e0e0); transition:background .15s;
    }
    .gt-tag-link:hover { background:var(--gt-light,#e0e0e0); }
    @media print {
      .gt-nav, .gt-breadcrumb, aside, .gt-lang-btn, .gt-share-area,
      .gt-footer, form, .gt-lang-toggle, #cookieBanner { display:none !important; }
      .gt-article-layout { display:block !important; }
      body { font-size:12pt; }
      .gt-article-content { max-width:100% !important; }
    }
  </style>
</head>
<body>
<div id="gt-progress-bar"></div>
<%- include('../partials/nav') %>
<% if (typeof isPreview !== 'undefined' && isPreview) { %>
<div style="background:#e67e22;color:#fff;text-align:center;padding:.6rem 1rem;font-size:.85rem;font-weight:600;position:sticky;top:0;z-index:100">
  <i class="fas fa-eye"></i> Preview Mode — This article is not published yet.
  <a href="/admin/articles/<%= article.id %>/edit" style="color:#fff;text-decoration:underline;margin-left:1rem">Back to Editor</a>
</div>
<% } %>
<div class="gt-breadcrumb">
  <div class="container">
    <a href="/">Home</a><span>/</span>
    <a href="/articles">News</a><span>/</span>
    <% if (article.cat_slug) { %><a href="/category/<%= article.cat_slug %>"><%= article.cat_name %></a><span>/</span><% } %>
    <span><%= article.title.substring(0,50) %></span>
  </div>
</div>
<main class="section">
  <div class="container">
    <div class="gt-article-layout">
      <article>
        <div class="gt-article-header">
          <% if (article.cat_name) { %><span class="gt-cat-badge" style="background:<%= article.cat_color||'#e63946' %>"><%= article.cat_name %></span><% } %>
          <h1><%= article.title %></h1>
          <div class="gt-article-meta">
            <span>
              <i class="fas fa-user"></i>
              <% if (article.author_username) { %>
              <a href="/author/<%= article.author_username %>" style="color:inherit"><%= article.author_name %></a>
              <% } else { %><%= article.author_name %><% } %>
            </span>
            <span><i class="fas fa-calendar"></i> <%= new Date(article.published_at).toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></span>
            <span><i class="fas fa-clock"></i> <%= article.reading_time %> min read</span>
            <span><i class="fas fa-eye"></i> <%= article.views %> views</span>
          </div>
        </div>

        <% if (article.cover_image) { %>
        <div class="gt-article-cover">
          <img src="/uploads/articles/<%= article.cover_image %>" alt="<%= article.title %>">
        </div>
        <% } %>

        <% const hasHi = article.content_hi && article.content_hi.trim().length > 10; %>
        <% const hasTe = article.content_te && article.content_te.trim().length > 10; %>
        <% if (hasHi || hasTe) { %>
        <div style="display:flex;gap:.5rem;margin-bottom:1.25rem;align-items:center" class="gt-lang-toggle">
          <span style="font-size:.78rem;color:var(--gt-gray);margin-right:.25rem">Read in:</span>
          <button class="gt-lang-btn active" data-lang="en" onclick="switchLang('en')">English</button>
          <% if (hasHi) { %><button class="gt-lang-btn" data-lang="hi" onclick="switchLang('hi')">हिंदी</button><% } %>
          <% if (hasTe) { %><button class="gt-lang-btn" data-lang="te" onclick="switchLang('te')">తెలుగు</button><% } %>
        </div>
        <% } %>

        <div class="gt-article-content" id="content-en">
          <%- article.content || '<p>Content coming soon.</p>' %>
        </div>
        <% if (hasHi) { %>
        <div class="gt-article-content" id="content-hi" style="display:none"><%- article.content_hi %></div>
        <% } %>
        <% if (hasTe) { %>
        <div class="gt-article-content" id="content-te" style="display:none"><%- article.content_te %></div>
        <% } %>

        <!-- Tags -->
        <% if (tags && tags.length > 0) { %>
        <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:.5rem;align-items:center">
          <span style="font-size:.8rem;color:var(--gt-gray);font-weight:600"><i class="fas fa-tag"></i></span>
          <% tags.forEach(t => { %><a href="/tag/<%= t.slug %>" class="gt-tag-link">#<%= t.name %></a><% }) %>
        </div>
        <% } %>

        <!-- Share + Print -->
        <div class="gt-share-area" style="margin-top:1.5rem;padding:1.25rem;background:var(--gt-off);border-radius:var(--gt-radius);display:flex;flex-wrap:wrap;gap:.6rem;align-items:center">
          <span style="font-size:.82rem;font-weight:700;color:var(--gt-dark);margin-right:.25rem">Share:</span>
          <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' ' + canonicalUrl) %>" target="_blank" rel="noopener" class="gt-share-btn" style="background:#25D366;color:#fff"><i class="fab fa-whatsapp"></i> WhatsApp</a>
          <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(article.title) %>&url=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" class="gt-share-btn" style="background:#1DA1F2;color:#fff"><i class="fab fa-x-twitter"></i> Twitter</a>
          <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonicalUrl) %>" target="_blank" rel="noopener" class="gt-share-btn" style="background:#1877F2;color:#fff"><i class="fab fa-facebook-f"></i> Facebook</a>
          <button onclick="copyLink()" class="gt-share-btn" style="background:var(--gt-dark);color:#fff"><i class="fas fa-link"></i> <span id="copyLabel">Copy Link</span></button>
          <button onclick="window.print()" class="gt-share-btn" style="background:#888;color:#fff;margin-left:auto"><i class="fas fa-print"></i> Print</button>
        </div>

        <!-- Author bio box -->
        <% if (article.author_username && (article.author_bio || article.author_avatar)) { %>
        <div style="margin-top:2rem;padding:1.25rem;background:var(--gt-off);border-radius:var(--gt-radius-lg);display:flex;gap:1rem;align-items:flex-start">
          <div style="flex-shrink:0">
            <% if (article.author_avatar) { %>
            <img src="/uploads/avatars/<%= article.author_avatar %>" alt="<%= article.author_name %>" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid var(--gt-green)">
            <% } else { %>
            <div style="width:64px;height:64px;border-radius:50%;background:var(--gt-green);display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:800;color:#fff"><%= (article.author_name||'?').charAt(0).toUpperCase() %></div>
            <% } %>
          </div>
          <div style="flex:1;min-width:0">
            <div style="font-size:.72rem;color:var(--gt-gray);text-transform:uppercase;letter-spacing:.06em;font-weight:700;margin-bottom:.2rem">Written by</div>
            <a href="/author/<%= article.author_username %>" style="font-size:1rem;font-weight:800;color:var(--gt-dark);text-decoration:none"><%= article.author_name %></a>
            <% if (article.author_bio) { %>
            <p style="margin:.4rem 0 .6rem;font-size:.85rem;color:var(--gt-gray);line-height:1.6"><%= article.author_bio %></p>
            <% } %>
            <a href="/author/<%= article.author_username %>" style="font-size:.78rem;font-weight:600;color:var(--gt-green)">More articles <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <% } %>

        <!-- Comments section -->
        <% const commentsEnabled = settings?.comments_enabled !== '0'; %>
        <div style="margin-top:3rem;padding-top:2rem;border-top:2px solid var(--gt-light)">
          <h2 style="font-size:1.2rem;font-weight:800;margin-bottom:1.5rem">Comments (<%= comments.length %>)</h2>

          <% if (success === 'comment') { %>
          <div class="gt-alert gt-alert-success"><i class="fas fa-check-circle"></i> Your comment is awaiting moderation. Thank you!</div>
          <% } %>
          <% if (error) { %>
          <div class="gt-alert gt-alert-error"><%= error %></div>
          <% } %>

          <% if (comments.length > 0) { %>
          <% comments.forEach(c => { %>
          <div class="gt-comment">
            <div class="gt-comment-header">
              <span class="gt-comment-name"><i class="fas fa-user-circle" style="color:var(--gt-green)"></i> <%= c.name %></span>
              <span class="gt-comment-date"><%= new Date(c.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
            </div>
            <p><%= c.content %></p>
          </div>
          <% }) %>
          <% } else { %>
          <p style="color:var(--gt-gray);font-size:.9rem;margin-bottom:1.5rem">Be the first to comment on this article.</p>
          <% } %>

          <% if (commentsEnabled) { %>
          <div style="background:var(--gt-off);border-radius:var(--gt-radius-lg);padding:1.5rem;margin-top:1.5rem">
            <h3 style="font-size:1rem;font-weight:700;margin-bottom:1.25rem">Leave a Comment</h3>
            <form action="/article/<%= article.slug %>/comment" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
                <div class="gt-form-group"><label>Name *</label><input type="text" name="name" required placeholder="Your name"></div>
                <div class="gt-form-group"><label>Email (optional)</label><input type="email" name="email" placeholder="your@email.com"></div>
              </div>
              <div class="gt-form-group"><label>Comment *</label><textarea name="content" required placeholder="Share your thoughts..." style="min-height:100px"></textarea></div>
              <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Submit Comment</button>
              <% if (settings?.comments_moderation !== '0') { %>
              <small style="display:block;margin-top:.5rem;color:var(--gt-gray);font-size:.75rem">Comments are moderated and will appear after review.</small>
              <% } %>
            </form>
          </div>
          <% } %>
        </div>
      </article>

      <aside>
        <% if (related && related.length > 0) { %>
        <div class="gt-sidebar-section" style="background:var(--gt-white);border-radius:var(--gt-radius-lg);padding:1.25rem;box-shadow:var(--gt-shadow)">
          <h4>Related Articles</h4>
          <% related.forEach(r => { %>
          <a href="/article/<%= r.slug %>" class="gt-sidebar-article" style="text-decoration:none;display:flex;gap:.75rem;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--gt-light)">
            <div class="gt-sidebar-thumb">
              <% if (r.cover_image) { %><img src="/uploads/articles/<%= r.cover_image %>" alt="<%= r.title %>"><% } %>
            </div>
            <div>
              <h5 style="font-size:.82rem;font-weight:600;color:var(--gt-dark);line-height:1.4"><%= r.title %></h5>
              <span style="font-size:.72rem;color:var(--gt-gray)"><%= new Date(r.published_at).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> · <%= r.reading_time %> min</span>
            </div>
          </a>
          <% }) %>
        </div>
        <% } %>

        <div style="background:var(--gt-dark);color:var(--gt-white);border-radius:var(--gt-radius-lg);padding:1.5rem;margin-top:1.5rem">
          <div style="font-size:1.2rem;font-weight:800;margin-bottom:.5rem"><span style="color:var(--gt-red)">G</span>Times</div>
          <p style="font-size:.85rem;color:#aaa;line-height:1.6"><%= settings?.site_tagline || 'Your School. Your Stories.' %></p>
        </div>
      </aside>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
<script>
(function() {
  const bar = document.getElementById('gt-progress-bar');
  if (!bar) return;
  function update() {
    const el = document.documentElement;
    const scrolled = el.scrollTop || document.body.scrollTop;
    const total = el.scrollHeight - el.clientHeight;
    bar.style.width = (total > 0 ? Math.min(100, (scrolled / total) * 100) : 0) + '%';
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

function switchLang(lang) {
  ['en','hi','te'].forEach(l => {
    const el = document.getElementById('content-' + l);
    if (el) el.style.display = l === lang ? 'block' : 'none';
  });
  document.querySelectorAll('.gt-lang-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.lang === lang);
  });
}
function copyLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const lbl = document.getElementById('copyLabel');
    lbl.textContent = 'Copied!';
    setTimeout(() => lbl.textContent = 'Copy Link', 2000);
  });
}
</script>
</body>
</html>

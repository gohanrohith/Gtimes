<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('../partials/nav') %>
<div class="gt-page-hero">
  <div class="container">
    <h1>About GTimes</h1>
    <p>The student media platform of Greenwood High School</p>
  </div>
</div>
<main class="section">
  <div class="container" style="max-width:760px;margin:0 auto">

    <div style="text-align:center;margin-bottom:3rem">
      <div style="font-size:3rem;font-weight:900;margin-bottom:.5rem">
        <span style="color:var(--gt-red)">G</span><span style="color:var(--gt-dark)">Times</span>
      </div>
      <p style="color:var(--gt-gray);font-size:1.05rem"><%= settings?.site_tagline || 'Your School. Your Stories.' %></p>
    </div>

    <div class="gt-article-content">
      <p>GTimes is the official student media platform of <strong>Greenwood High School, Warangal</strong>. We cover news, events, achievements, and stories from all Greenwood campuses — giving students, parents, and staff a window into the vibrant life of our school community.</p>

      <h2>What We Cover</h2>
      <ul>
        <li><strong>School News</strong> — Announcements, policy updates, and important notices</li>
        <li><strong>Achievements</strong> — Student and staff milestones worth celebrating</li>
        <li><strong>Sports</strong> — Match reports, tournament results, and athlete spotlights</li>
        <li><strong>Campus Life</strong> — Day-to-day moments and student experiences</li>
        <li><strong>Education</strong> — Academic programmes, curriculum, and learning</li>
        <li><strong>Community</strong> — Events, outreach, and stories beyond the campus gate</li>
      </ul>

      <h2>Our Campuses</h2>
      <p>GTimes serves all five Greenwood campuses:</p>
      <ul>
        <li>Greenwood High School, Hasanparthy (Est. 2003)</li>
        <li>Greenwood High School, Hunter Road (Est. 2009)</li>
        <li>Greenwood High School, Mancherial (Est. 2022)</li>
        <li>Greenwood High School, Gopalpur (Est. 2023)</li>
        <li>Greenwood High School, Naimnagar (Est. 2025)</li>
      </ul>

      <h2>Contact</h2>
      <p>Have a story tip, correction, or feedback? Write to us at <a href="mailto:gtimes@ghs.ac.in">gtimes@ghs.ac.in</a></p>
      <p>Visit the main school website at <a href="https://ghs.ac.in" target="_blank" rel="noopener">ghs.ac.in</a></p>
    </div>
  </div>
</main>
<% if (reviews && reviews.length > 0) { %>
<section class="section" style="background:#f8f9fa;padding-top:0;margin-top:0">
  <div class="container">
    <div style="text-align:center;margin-bottom:2rem">
      <span class="gt-tag">Community</span>
      <h2 style="font-size:1.6rem;font-weight:800;margin:.5rem 0 0">What Parents Say</h2>
      <div class="gt-google-rating-badge">
        <svg width="15" height="15" viewBox="0 0 24 24" style="flex-shrink:0"><path d="M21.35 11.1H12v2.8h5.35c-.5 2.3-2.5 3.9-5.35 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.5 0 2.9.6 3.95 1.55L18.1 5.1C16.45 3.55 14.35 2.6 12 2.6 6.75 2.6 2.5 6.85 2.5 12.1s4.25 9.5 9.5 9.5c5.5 0 9.1-3.85 9.1-9.3 0-.7-.1-1.25-.25-1.7z" fill="#4285F4"/></svg>
        <span>Reviews from Google</span>
      </div>
    </div>
    <div class="gt-reviews-grid">
      <% reviews.forEach(r => {
        const initial = (r.author_name || 'P').charAt(0).toUpperCase();
        const stars = parseInt(r.rating) || 5;
      %>
      <div class="gt-review-card">
        <div class="gt-review-quote"><i class="fas fa-quote-left"></i></div>
        <p class="gt-review-text"><%= r.review_text.length > 200 ? r.review_text.slice(0,200) + '…' : r.review_text %></p>
        <div class="gt-review-stars">
          <% for(let i=1;i<=5;i++) { %><i class="fas fa-star" style="color:<%= i<=stars?'#FBBF24':'#D1D5DB' %>;font-size:.78rem"></i><% } %>
        </div>
        <div class="gt-review-footer">
          <% if (r.profile_photo_url) { %>
          <img src="<%= r.profile_photo_url %>" alt="<%= r.author_name %>" class="gt-review-avatar" loading="lazy">
          <% } else { %>
          <div class="gt-review-avatar-initial"><%= initial %></div>
          <% } %>
          <div class="gt-review-meta">
            <span class="gt-review-name"><%= r.author_name %></span>
            <div class="gt-review-source-row">
              <svg width="10" height="10" viewBox="0 0 24 24"><path d="M21.35 11.1H12v2.8h5.35c-.5 2.3-2.5 3.9-5.35 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.5 0 2.9.6 3.95 1.55L18.1 5.1C16.45 3.55 14.35 2.6 12 2.6 6.75 2.6 2.5 6.85 2.5 12.1s4.25 9.5 9.5 9.5c5.5 0 9.1-3.85 9.1-9.3 0-.7-.1-1.25-.25-1.7z" fill="#4285F4"/></svg>
              <span>Google Review</span>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>

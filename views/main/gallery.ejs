<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<%- include('../partials/nav') %>
<div class="gt-page-hero">
  <div class="container">
    <h1>Photo Gallery</h1>
    <p>Moments captured from Greenwood campuses</p>
  </div>
</div>
<main class="section">
  <div class="container">
    <% if (albums && albums.length > 0) { %>
    <div class="gt-gallery-grid">
      <% albums.forEach(album => { %>
      <a href="/gallery/<%= album.slug %>" class="gt-album-card" style="text-decoration:none">
        <div class="gt-album-cover">
          <% if (album.cover_image) { %>
          <img src="/uploads/gallery/<%= album.cover_image %>" alt="<%= album.title %>" loading="lazy">
          <% } else { %>
          <div class="gt-album-placeholder"><i class="fas fa-images"></i></div>
          <% } %>
          <div class="gt-album-overlay">
            <span><i class="fas fa-images"></i> <%= album.photo_count || 0 %> photos</span>
          </div>
        </div>
        <div class="gt-album-info">
          <h3><%= album.title %></h3>
          <% if (album.description) { %><p><%= album.description.substring(0,80) %><%= album.description.length>80?'…':'' %></p><% } %>
          <span class="gt-album-date"><i class="fas fa-calendar-alt"></i> <%= new Date(album.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="gt-empty"><i class="fas fa-images"></i><p>No photo albums yet.</p></div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>

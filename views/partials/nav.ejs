<nav class="gt-nav" id="gtNav">
  <div class="gt-nav-inner">
    <a href="/" class="gt-brand">
      <img src="/GTIMES-PNG.png" alt="GTimes" class="gt-brand-logo"
           onerror="this.style.display='none'; this.nextElementSibling.style.display='inline'">
      <span class="gt-brand-fallback" style="display:none"><span class="gt-brand-g">G</span><span class="gt-brand-times">Times</span></span>
    </a>

    <button class="gt-nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

    <ul class="gt-nav-menu" id="navMenu">
      <li class="gt-nav-search-mobile">
        <form action="/search" method="GET" style="padding:.5rem .75rem">
          <div style="display:flex;gap:.5rem;align-items:center;background:var(--gt-off);border:1px solid var(--gt-border);border-radius:20px;padding:.3rem .75rem">
            <input type="text" name="q" placeholder="Search articles..." style="flex:1;border:none;background:none;font-family:inherit;font-size:.88rem;outline:none;color:var(--gt-ink)">
            <button type="submit" style="background:none;border:none;cursor:pointer;color:var(--gt-gray);padding:0"><i class="fas fa-search"></i></button>
          </div>
        </form>
      </li>
      <li><a href="/" class="gt-nav-link">Home</a></li>
      <li><a href="/articles" class="gt-nav-link">News</a></li>
      <li class="gt-has-dropdown">
        <a href="/articles" class="gt-nav-link">Categories <i class="fas fa-chevron-down"></i></a>
        <ul class="gt-dropdown">
          <% if (typeof categories !== 'undefined') { categories.forEach(c => { %>
          <li><a href="/category/<%= c.slug %>" style="border-left:3px solid <%= c.color %>"><%= c.name %></a></li>
          <% }) } %>
        </ul>
      </li>
      <li><a href="/events" class="gt-nav-link">Events</a></li>
      <li><a href="/gallery" class="gt-nav-link">Gallery</a></li>
      <li><a href="/videos" class="gt-nav-link">Videos</a></li>
      <li><a href="/about" class="gt-nav-link">About</a></li>
    </ul>

    <div class="gt-nav-search">
      <form action="/search" method="GET" style="display:flex;align-items:center;gap:.5rem">
        <input type="text" name="q" placeholder="Search..." class="gt-search-input">
        <button type="submit" style="background:none;border:none;cursor:pointer;color:var(--gt-gray)"><i class="fas fa-search"></i></button>
      </form>
    </div>
  </div>
</nav>

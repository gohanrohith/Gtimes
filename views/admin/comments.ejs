<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="gt-admin">
<%- include('../partials/admin-topbar') %>
<div class="gt-admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="gt-admin-main">
    <div class="gt-admin-page-header">
      <h1>Comments</h1>
    </div>

    <!-- Tabs -->
    <div class="gt-tab-bar" style="margin-bottom:1.25rem">
      <a href="/comments" class="gt-tab <%= !filter ? 'active' : '' %>">All</a>
      <a href="/comments?status=pending" class="gt-tab <%= filter==='pending' ? 'active' : '' %>">
        Pending <% if (pendingCount) { %><span class="gt-tab-badge"><%= pendingCount %></span><% } %>
      </a>
      <a href="/comments?status=approved" class="gt-tab <%= filter==='approved' ? 'active' : '' %>">Approved</a>
      <a href="/comments?status=spam" class="gt-tab <%= filter==='spam' ? 'active' : '' %>">Spam</a>
    </div>

    <% if (success) { %>
    <div class="gt-alert gt-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <div class="gt-admin-card">
      <% if (comments && comments.length > 0) { %>
      <table class="gt-admin-table gt-admin-table-full">
        <thead>
          <tr>
            <th>Author</th>
            <th>Comment</th>
            <th>Article</th>
            <th>Date</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% comments.forEach(c => { %>
          <tr>
            <td>
              <div style="font-weight:600;font-size:.88rem"><%= c.name %></div>
              <% if (c.email) { %><div style="font-size:.75rem;color:var(--gt-gray)"><%= c.email %></div><% } %>
            </td>
            <td style="max-width:280px">
              <div style="font-size:.85rem;line-height:1.5"><%= c.content.substring(0,120) %><%= c.content.length>120?'…':'' %></div>
            </td>
            <td style="font-size:.82rem;max-width:160px">
              <% if (c.article_title) { %><a href="/article/<%= c.article_slug %>" target="_blank" style="color:var(--gt-dark)"><%= c.article_title.substring(0,40) %><%= c.article_title.length>40?'…':'' %></a><% } %>
            </td>
            <td style="font-size:.8rem;white-space:nowrap"><%= new Date(c.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
            <td><span class="gt-badge <%= c.status==='approved'?'gt-badge-success':c.status==='spam'?'gt-badge-danger':'gt-badge-warn' %>"><%= c.status %></span></td>
            <td style="text-align:right;white-space:nowrap">
              <% if (c.status !== 'approved') { %>
              <form action="/comments/<%= c.id %>/approve" method="POST" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-success" title="Approve"><i class="fas fa-check"></i></button>
              </form>
              <% } %>
              <% if (c.status !== 'spam') { %>
              <form action="/comments/<%= c.id %>/spam" method="POST" style="display:inline;margin-left:4px">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-warn" title="Mark Spam"><i class="fas fa-ban"></i></button>
              </form>
              <% } %>
              <form action="/comments/<%= c.id %>/delete" method="POST" style="display:inline;margin-left:4px">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-xs btn-danger gt-confirm-delete" title="Delete"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="gt-empty"><i class="fas fa-comments"></i><p>No comments <%= filter ? 'with status "'+filter+'"' : '' %>.</p></div>
      <% } %>
    </div>
  </main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="gt-admin">
<%- include('../partials/admin-topbar') %>
<div class="gt-admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="gt-admin-main">

    <% if (!album) { %>
    <!-- New Album form -->
    <div class="gt-admin-page-header">
      <h1>New Album</h1>
      <a href="/admin/gallery" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <% if (error) { %><div class="gt-alert gt-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

    <div class="gt-admin-card" style="max-width:560px">
      <form action="/admin/gallery/new" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="gt-form-group">
          <label>Album Title *</label>
          <input type="text" name="title" required placeholder="e.g. Annual Day 2026">
        </div>
        <div class="gt-form-group">
          <label>Campus / Branch</label>
          <select name="campus">
            <option value="all">All Campuses</option>
            <option value="Hasanparthy">Hasanparthy</option>
            <option value="Hunter Road">Hunter Road</option>
            <option value="Mancherial">Mancherial</option>
            <option value="Gopalpur">Gopalpur</option>
            <option value="Naimnagar">Naimnagar</option>
          </select>
        </div>
        <div class="gt-form-group">
          <label>Description</label>
          <textarea name="description" rows="3" placeholder="Brief description…"></textarea>
        </div>
        <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> Create Album</button>
      </form>
    </div>

    <% } else { %>
    <!-- Upload photos to existing album -->
    <div class="gt-admin-page-header">
      <h1>Upload Photos — <%= album.title %></h1>
      <a href="/admin/gallery" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to Gallery</a>
    </div>

    <% if (success) { %>
    <div class="gt-alert gt-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <div class="gt-admin-card" style="max-width:640px;margin-bottom:2rem">
      <form action="/admin/gallery/<%= album.id %>/upload?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" id="uploadForm">
        <div class="gt-form-group">
          <label>Select Photos <span style="font-weight:400;color:var(--gt-gray)">(multiple allowed, max 5 MB each)</span></label>
          <input type="file" name="photos" id="photoInput" accept="image/*" multiple class="gt-file-input">
          <label for="photoInput" class="btn btn-outline" style="margin-top:.5rem;display:inline-flex"><i class="fas fa-images"></i> Choose Photos</label>
        </div>
        <div id="previewGrid" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem"></div>
        <button type="submit" class="btn btn-primary"><i class="fas fa-upload"></i> Upload</button>
      </form>
    </div>

    <!-- Existing photos -->
    <% if (photos && photos.length > 0) { %>
    <h3 style="font-size:.95rem;font-weight:700;margin-bottom:1rem">Album Photos (<%= photos.length %>)</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem">
      <% photos.forEach(photo => { %>
      <div style="border-radius:8px;overflow:hidden;background:var(--gt-off);border:2px solid <%= album.cover_image===photo.filename ? 'var(--gt-green)' : 'transparent' %>">
        <div style="position:relative">
          <img src="/uploads/gallery/<%= photo.filename %>" style="width:100%;height:120px;object-fit:cover;display:block" loading="lazy" onerror="this.style.display='none'">
          <% if (album.cover_image === photo.filename) { %>
          <span style="position:absolute;top:4px;left:4px;background:var(--gt-green);color:#fff;font-size:.65rem;font-weight:700;padding:2px 6px;border-radius:10px"><i class="fas fa-star"></i> Cover</span>
          <% } %>
          <form action="/admin/gallery/photo/<%= photo.id %>/delete" method="POST" style="position:absolute;top:4px;right:4px">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-xs btn-danger gt-confirm-delete" style="padding:4px 6px" title="Delete photo"><i class="fas fa-times"></i></button>
          </form>
        </div>
        <!-- Caption edit -->
        <form action="/admin/gallery/photo/<%= photo.id %>/caption" method="POST" style="padding:.5rem;display:flex;gap:.4rem;align-items:center">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="text" name="caption" value="<%= photo.caption||'' %>" placeholder="Add caption…" style="flex:1;padding:.3rem .5rem;border:1px solid var(--gt-light);border-radius:4px;font-family:inherit;font-size:.75rem">
          <button type="submit" class="btn btn-xs btn-outline" title="Save caption"><i class="fas fa-check"></i></button>
        </form>
        <!-- Set as cover -->
        <% if (album.cover_image !== photo.filename) { %>
        <form action="/admin/gallery/<%= album.id %>/cover/<%= photo.id %>" method="POST" style="padding:0 .5rem .5rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-xs btn-outline" style="width:100%;justify-content:center"><i class="fas fa-star"></i> Set as Cover</button>
        </form>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } %>
    <% } %>

  </main>
</div>
<script src="/js/admin.js"></script>
<script>
document.getElementById('photoInput')?.addEventListener('change', function() {
  const grid = document.getElementById('previewGrid');
  grid.innerHTML = '';
  Array.from(this.files).forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.createElement('img');
      img.src = e.target.result;
      img.style.cssText = 'width:80px;height:60px;object-fit:cover;border-radius:4px;border:2px solid var(--gt-lime)';
      grid.appendChild(img);
    };
    reader.readAsDataURL(file);
  });
});
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .gt-lang-tabs { display:flex; gap:.5rem; margin-bottom:0; border-bottom:2px solid var(--gt-light,#e8e8e8); padding-bottom:0; }
    .gt-lang-tab {
      padding:.5rem 1.1rem; border:none; background:none; cursor:pointer;
      font-family:inherit; font-size:.85rem; font-weight:600; color:var(--gt-gray,#888);
      border-bottom:2px solid transparent; margin-bottom:-2px; border-radius:0;
      transition:color .15s, border-color .15s;
    }
    .gt-lang-tab:hover { color:var(--gt-dark,#111); }
    .gt-lang-tab.active { color:var(--gt-green,#00663A); border-bottom-color:var(--gt-green,#00663A); }
    .gt-lang-panel { padding-top:1rem; }
    .gt-lang-hint {
      font-size:.78rem; color:var(--gt-gray,#888); margin-bottom:.6rem;
      display:flex; align-items:center; gap:.4rem;
    }
  </style>
</head>
<body class="gt-admin">
<%- include('../partials/admin-topbar') %>
<div class="gt-admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="gt-admin-main">
    <div class="gt-admin-page-header">
      <h1><%= article ? 'Edit Article' : 'New Article' %></h1>
      <a href="/admin/articles" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <% if (errors && errors.length > 0) { %>
    <div class="gt-alert gt-alert-error">
      <ul style="margin:0;padding-left:1.2rem">
        <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
      </ul>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="gt-alert gt-alert-error"><%= error %></div>
    <% } %>

    <form action="<%= article ? '/admin/articles/'+article.id+'/edit' : '/admin/articles/new' %>?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" id="articleForm">
      <!-- Hidden inputs — synced from Quill on submit -->
      <input type="hidden" name="content"      id="inputEn">
      <input type="hidden" name="content_hi"   id="inputHi">
      <input type="hidden" name="content_te"   id="inputTe">
      <input type="hidden" name="also_publish" id="alsoPublish" value="">

      <div class="gt-form-2col">

        <!-- Left column -->
        <div>
          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <div class="gt-form-group">
              <label>Title *</label>
              <input type="text" name="title" value="<%= article?.title||'' %>" required placeholder="Article headline" class="gt-title-input">
            </div>
            <div class="gt-form-group">
              <label>Excerpt <span style="font-weight:400;color:var(--gt-gray)">(shown in article cards)</span></label>
              <textarea name="excerpt" rows="2" placeholder="Brief summary…"><%= article?.excerpt||'' %></textarea>
            </div>
          </div>

          <!-- Language tabs -->
          <div class="gt-admin-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0">
              <div class="gt-lang-tabs" style="border-bottom:none;padding-bottom:0;flex:1">
                <button type="button" class="gt-lang-tab active" data-target="tab-en">English</button>
                <button type="button" class="gt-lang-tab"        data-target="tab-hi">हिंदी</button>
                <button type="button" class="gt-lang-tab"        data-target="tab-te">తెలుగు</button>
              </div>
              <button type="button" id="insertGalleryBtn" class="btn btn-sm btn-outline" style="flex-shrink:0;margin-left:.75rem">
                <i class="fas fa-images"></i> Insert Gallery
              </button>
            </div>
            <div style="border-top:2px solid var(--gt-light,#e8e8e8);margin-bottom:0"></div>

            <div id="tab-en" class="gt-lang-panel">
              <div id="quillEn" style="min-height:380px;background:#fff"><%- article?.content||'' %></div>
              <div id="wordCountBar" style="display:flex;align-items:center;justify-content:space-between;padding:.5rem .75rem;background:var(--gt-off);border-top:1px solid var(--gt-light);font-size:.78rem;border-radius:0 0 6px 6px">
                <span id="wordCountMsg" style="font-weight:600"></span>
                <span><span id="wordCountNum" style="font-weight:700">0</span> / 500 words</span>
              </div>
            </div>

            <div id="tab-hi" class="gt-lang-panel">
              <p class="gt-lang-hint"><i class="fas fa-info-circle"></i> Write in English, copy to ChatGPT/Gemini → ask for Hindi translation → paste here.</p>
              <div id="quillHi" style="min-height:380px;background:#fff"><%- article?.content_hi||'' %></div>
            </div>

            <div id="tab-te" class="gt-lang-panel">
              <p class="gt-lang-hint"><i class="fas fa-info-circle"></i> Write in English, copy to ChatGPT/Gemini → ask for Telugu translation → paste here.</p>
              <div id="quillTe" style="min-height:380px;background:#fff"><%- article?.content_te||'' %></div>
            </div>
          </div>
        </div>

        <!-- Right column -->
        <div>
          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:1rem">Publish</h4>
            <% if (article?.status === 'published') { %>
            <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.75rem;font-size:.8rem;color:var(--gt-green);font-weight:600"><i class="fas fa-circle" style="font-size:.5rem"></i> Published</div>
            <% } else if (article?.scheduled_at) { %>
            <div style="font-size:.78rem;color:#e67e22;font-weight:600;margin-bottom:.75rem"><i class="fas fa-clock"></i> Scheduled: <%= new Date(article.scheduled_at).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
            <% } else { %>
            <div style="font-size:.78rem;color:var(--gt-gray);margin-bottom:.75rem">Draft — not visible to public</div>
            <% } %>
            <div class="gt-form-group">
              <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
                <input type="checkbox" name="featured" value="1" <%= article?.featured?'checked':'' %> style="width:auto">
                Mark as Featured Story
              </label>
            </div>
            <div class="gt-form-group">
              <label>Schedule Publishing <span style="font-weight:400;color:var(--gt-gray)">(optional)</span></label>
              <input type="datetime-local" name="scheduled_at"
                value="<%= article?.scheduled_at ? new Date(article.scheduled_at).toISOString().slice(0,16) : '' %>">
              <small style="color:var(--gt-gray);font-size:.73rem">Leave blank to save as draft. Article auto-publishes at this date/time.</small>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">
              <i class="fas fa-save"></i> Save Draft
            </button>
            <% const canPublish = locals.adminRole === 'editor' || locals.adminRole === 'super'; %>
            <% if (article) { %>
              <% if (canPublish && article.status !== 'published') { %>
              <button type="button" onclick="document.getElementById('alsoPublish').value='1';document.getElementById('articleForm').requestSubmit()" class="btn btn-success" style="width:100%;justify-content:center;margin-top:.5rem"><i class="fas fa-check"></i> Publish Now</button>
              <% } else if (!canPublish && article.status === 'draft') { %>
              <button type="submit" form="reviewForm" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:.5rem"><i class="fas fa-paper-plane"></i> Submit for Review</button>
              <% } %>
              <a href="/admin/articles/<%= article.id %>/preview" target="_blank" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:.5rem">
                <i class="fas fa-eye"></i> Preview
              </a>
            <% } %>
          </div>

          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:1rem">Category</h4>
            <div class="gt-form-group">
              <select name="category_id">
                <option value="">— Uncategorised —</option>
                <% categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= article?.category_id==c.id?'selected':'' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:1rem">Cover Image</h4>
            <% if (article?.cover_image) { %>
            <div style="margin-bottom:.75rem;border-radius:6px;overflow:hidden"><img src="/uploads/articles/<%= article.cover_image %>" style="width:100%;max-height:140px;object-fit:cover" id="coverPreview"></div>
            <% } else { %>
            <div style="height:100px;background:var(--gt-off);border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:.75rem;color:var(--gt-gray-lt)" id="coverPlaceholder"><i class="fas fa-image" style="font-size:1.5rem"></i></div>
            <img id="coverPreview" style="display:none;width:100%;max-height:140px;object-fit:cover;border-radius:6px;margin-bottom:.75rem">
            <% } %>
            <input type="file" name="cover_image" accept="image/*" id="coverInput" class="gt-file-input">
            <label for="coverInput" class="btn btn-sm btn-outline" style="width:100%;justify-content:center"><i class="fas fa-upload"></i> Upload Image</label>
            <% if (article?.cover_image) { %>
            <label style="display:flex;align-items:center;gap:.5rem;margin-top:.5rem;font-size:.8rem;cursor:pointer">
              <input type="checkbox" name="remove_cover" value="1" style="width:auto"> Remove current image
            </label>
            <% } %>
          </div>

          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:1rem">Author</h4>
            <div class="gt-form-group">
              <input type="text" name="author_name" value="<%= article?.author_name||admin.username %>" placeholder="Author name">
            </div>
          </div>

          <div class="gt-admin-card" style="margin-bottom:1.25rem">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:.5rem">Tags</h4>
            <p style="font-size:.75rem;color:var(--gt-gray);margin-bottom:.75rem">Comma-separated — e.g. <em>sports, cbse, warangal</em></p>
            <div class="gt-form-group">
              <input type="text" name="tags" value="<%= articleTags||'' %>" placeholder="tag1, tag2, tag3">
            </div>
          </div>

          <div class="gt-admin-card">
            <h4 style="font-size:.85rem;font-weight:700;margin-bottom:.25rem">Short URL <span style="font-weight:400;color:var(--gt-gray)">(optional)</span></h4>
            <p style="font-size:.75rem;color:var(--gt-gray);margin-bottom:.75rem">Custom name for the share link. Letters, numbers and hyphens only.</p>
            <div class="gt-form-group" style="margin-bottom:.5rem">
              <input type="text" name="short_slug" id="shortSlugInput"
                value="<%= article?.short_slug||'' %>"
                placeholder="e.g. sports-day-2025"
                pattern="[a-z0-9\-]+"
                style="text-transform:lowercase"
                oninput="this.value=this.value.toLowerCase().replace(/[^a-z0-9-]/g,'-').replace(/-{2,}/g,'-')">
            </div>
            <div style="font-size:.75rem;color:var(--gt-gray);background:var(--gt-off);border-radius:4px;padding:.4rem .6rem;word-break:break-all">
              gtimes.in/p/<span id="shortSlugPreview" style="color:var(--gt-ink);font-weight:600"><%= article?.short_slug || (article?.id ? article.id : '&lt;name&gt;') %></span>
            </div>
            <% if (article?.id && !article?.short_slug) { %>
            <small style="font-size:.7rem;color:var(--gt-gray);display:block;margin-top:.3rem"><i class="fas fa-info-circle"></i> Using ID-based URL by default. Set a custom name above to replace it.</small>
            <% } %>
          </div>
        </div>

      </div>
    </form>
    <% if (article) { %>
      <% if (locals.adminRole === 'editor' || locals.adminRole === 'super') { %>
      <% if (article.status !== 'published') { %>
      <form id="publishForm" action="/admin/articles/<%= article.id %>/publish" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      </form>
      <% } %>
      <% } else if (article.status === 'draft') { %>
      <form id="reviewForm" action="/admin/articles/<%= article.id %>/submit-review" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      </form>
      <% } %>
    <% } %>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
<script src="/js/admin.js"></script>
<script>
const CSRF = '<%= csrfToken %>';

const toolbarOptions = [
  [{ header: [2, 3, false] }],
  ['bold', 'italic', 'underline'],
  [{ list: 'ordered' }, { list: 'bullet' }],
  ['blockquote', 'link', 'image'],
  ['clean']
];

// Register custom Gallery blot so Quill 2 preserves <div class="gt-inline-gallery">
(function() {
  const BlockEmbed = Quill.import('blots/block/embed');
  class GalleryBlot extends BlockEmbed {
    static create(value) {
      const node = super.create();
      const albumId = (typeof value === 'object') ? value.albumId : value;
      const title   = (typeof value === 'object' && value.title) ? value.title : '';
      node.setAttribute('data-album', albumId);
      if (title) node.setAttribute('data-title', title);
      node.setAttribute('contenteditable', 'false');
      node.innerHTML = `<span style="display:flex;align-items:center;gap:.5rem;padding:.6rem 1rem;background:#f0f9f4;border:2px dashed #00663A;border-radius:6px;color:#00663A;font-size:.82rem;font-weight:600;pointer-events:none"><i class="fas fa-images"></i> Gallery: ${title || 'Album #' + albumId}</span>`;
      return node;
    }
    static value(domNode) {
      return { albumId: domNode.getAttribute('data-album'), title: domNode.getAttribute('data-title') || '' };
    }
  }
  GalleryBlot.blotName = 'gallery';
  GalleryBlot.tagName  = 'div';
  GalleryBlot.className = 'gt-inline-gallery';
  Quill.register(GalleryBlot);
})();

// Briefly make all panels block+off-screen so Quill can measure them during init
['tab-hi', 'tab-te'].forEach(id => {
  const el = document.getElementById(id);
  el.style.cssText = 'display:block;position:absolute;visibility:hidden;pointer-events:none';
});

function makeImageHandler(quill) {
  return function() {
    const input = document.createElement('input');
    input.type = 'file'; input.accept = 'image/*';
    input.onchange = () => {
      const file = input.files[0];
      if (!file) return;
      const fd = new FormData();
      fd.append('image', file);
      fd.append('_csrf', CSRF);
      fetch('/admin/articles/upload-image', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(data => {
          if (data.url) {
            const range = quill.getSelection(true);
            quill.insertEmbed(range.index, 'image', data.url);
            quill.setSelection(range.index + 1);
          } else { alert(data.error || 'Upload failed'); }
        })
        .catch(() => alert('Image upload failed'));
    };
    input.click();
  };
}

const quillEn = new Quill('#quillEn', { theme: 'snow', modules: { toolbar: toolbarOptions } });
const quillHi = new Quill('#quillHi', { theme: 'snow', modules: { toolbar: toolbarOptions } });
const quillTe = new Quill('#quillTe', { theme: 'snow', modules: { toolbar: toolbarOptions } });

quillEn.getModule('toolbar').addHandler('image', makeImageHandler(quillEn));
quillHi.getModule('toolbar').addHandler('image', makeImageHandler(quillHi));
quillTe.getModule('toolbar').addHandler('image', makeImageHandler(quillTe));

// Restore hidden state
['tab-hi', 'tab-te'].forEach(id => {
  const el = document.getElementById(id);
  el.style.cssText = 'display:none';
});

// Tab switching
document.querySelectorAll('.gt-lang-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.gt-lang-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.gt-lang-panel').forEach(p => p.style.display = 'none');
    btn.classList.add('active');
    document.getElementById(btn.dataset.target).style.display = 'block';
  });
});

// Sync all 3 editors to hidden inputs before submit
document.getElementById('articleForm').addEventListener('submit', function() {
  document.getElementById('inputEn').value = quillEn.root.innerHTML;
  document.getElementById('inputHi').value = quillHi.root.innerHTML;
  document.getElementById('inputTe').value = quillTe.root.innerHTML;
});

// Word counter for English editor
const WORD_MAX = 500;
function countWords(text) {
  return text.trim() === '' ? 0 : text.trim().split(/\s+/).length;
}
function updateWordCount() {
  const text  = quillEn.getText();
  const count = countWords(text);
  const numEl = document.getElementById('wordCountNum');
  const msgEl = document.getElementById('wordCountMsg');
  const bar   = document.getElementById('wordCountBar');
  numEl.textContent = count;
  if (count >= WORD_MAX) {
    numEl.style.color = '#e63946';
    bar.style.borderTop = '2px solid #e63946';
    msgEl.textContent  = 'Word limit reached — please trim your article.';
    msgEl.style.color  = '#e63946';
  } else if (count >= 400) {
    numEl.style.color = '#e67e22';
    bar.style.borderTop = '2px solid #e67e22';
    msgEl.textContent  = 'Getting long — ideal length is under 400 words.';
    msgEl.style.color  = '#e67e22';
  } else if (count >= 300) {
    numEl.style.color = '#00663A';
    bar.style.borderTop = '2px solid #00663A';
    msgEl.textContent  = 'Good length.';
    msgEl.style.color  = '#00663A';
  } else {
    numEl.style.color = '#888';
    bar.style.borderTop = '1px solid var(--gt-light)';
    msgEl.textContent  = '';
  }
}
quillEn.on('text-change', function() {
  const text  = quillEn.getText();
  const count = countWords(text);
  if (count >= WORD_MAX) {
    // block further typing — revert to last allowed state
    const delta = quillEn.getContents();
    // count again after potential paste
    const words = text.trim().split(/\s+/);
    if (words.length > WORD_MAX) {
      const allowed = words.slice(0, WORD_MAX).join(' ');
      quillEn.setText(allowed);
      quillEn.setSelection(quillEn.getLength());
    }
  }
  updateWordCount();
});
updateWordCount();

// Short URL live preview
const shortSlugInput = document.getElementById('shortSlugInput');
const shortSlugPreview = document.getElementById('shortSlugPreview');
if (shortSlugInput && shortSlugPreview) {
  const slugFallback = '<%= article?.id ? article.id : "<name>" %>';
  shortSlugInput.addEventListener('input', function() {
    shortSlugPreview.textContent = this.value || slugFallback;
  });
}

// Cover image preview
document.getElementById('coverInput')?.addEventListener('change', function() {
  const file = this.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const prev = document.getElementById('coverPreview');
    const ph   = document.getElementById('coverPlaceholder');
    if (ph) ph.style.display = 'none';
    prev.src = e.target.result;
    prev.style.display = 'block';
  };
  reader.readAsDataURL(file);
});
</script>

<!-- Gallery picker modal -->
<div id="galleryModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:2000;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;max-width:680px;width:92%;max-height:82vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.3)">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid #e9ecef">
      <h3 style="font-size:1rem;font-weight:700;margin:0"><i class="fas fa-images" style="color:var(--gt-green)"></i> Select Gallery Album</h3>
      <button id="galleryModalClose" type="button" style="background:none;border:none;font-size:1.25rem;cursor:pointer;color:#888">&times;</button>
    </div>
    <div id="galleryAlbumList" style="padding:1.25rem;overflow-y:auto;flex:1;display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem">
      <p style="color:#888;font-size:.88rem;grid-column:1/-1">Loading albums…</p>
    </div>
  </div>
</div>

<script>
(function() {
  let activeQuill = null;

  // Track which editor is active based on tab
  document.querySelectorAll('.gt-lang-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const map = { 'tab-en': 'quillEn', 'tab-hi': 'quillHi', 'tab-te': 'quillTe' };
      activeQuill = window[map[btn.dataset.target]] || null;
    });
  });
  // Default active editor
  activeQuill = window.quillEn;

  const modal     = document.getElementById('galleryModal');
  const albumList = document.getElementById('galleryAlbumList');
  let loaded = false;

  document.getElementById('insertGalleryBtn').addEventListener('click', () => {
    modal.style.display = 'flex';
    if (!loaded) {
      loaded = true;
      fetch('/admin/articles/galleries')
        .then(r => r.json())
        .then(albums => {
          if (!albums.length) {
            albumList.innerHTML = '<p style="color:#888;font-size:.88rem;grid-column:1/-1">No active gallery albums found. Create some in the Gallery section first.</p>';
            return;
          }
          albumList.innerHTML = albums.map(a => `
            <div class="gt-gallery-pick-card" data-album-id="${a.id}" data-album-title="${a.title.replace(/"/g,'&quot;')}"
                 style="cursor:pointer;border:2px solid #e9ecef;border-radius:8px;overflow:hidden;transition:border-color .15s"
                 onmouseover="this.style.borderColor='#00663A'" onmouseout="this.style.borderColor='#e9ecef'">
              <div style="height:100px;background:#f7f9fc;overflow:hidden">
                ${a.cover_image ? `<img src="/uploads/gallery/${a.cover_image}" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none'">` : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center"><i class="fas fa-images" style="font-size:1.5rem;color:#ccc"></i></div>'}
              </div>
              <div style="padding:.6rem .75rem">
                <div style="font-size:.82rem;font-weight:700;color:#111;margin-bottom:.15rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${a.title}</div>
                <div style="font-size:.72rem;color:#888">${a.photo_count} photo${a.photo_count===1?'':'s'}</div>
              </div>
            </div>`).join('');
          albumList.querySelectorAll('.gt-gallery-pick-card').forEach(card => {
            card.addEventListener('click', () => insertGallery(card.dataset.albumId, card.dataset.albumTitle));
          });
        })
        .catch(() => { albumList.innerHTML = '<p style="color:red;font-size:.88rem">Failed to load albums.</p>'; });
    }
  });

  document.getElementById('galleryModalClose').addEventListener('click', () => modal.style.display = 'none');
  modal.addEventListener('click', e => { if (e.target === modal) modal.style.display = 'none'; });

  function insertGallery(albumId, albumTitle) {
    const quill = activeQuill || window.quillEn;
    if (!quill) return;
    const range = quill.getSelection(true);
    const idx   = range ? range.index : quill.getLength() - 1;
    quill.insertEmbed(idx, 'gallery', { albumId, title: albumTitle }, Quill.sources.USER);
    quill.setSelection(idx + 1, Quill.sources.SILENT);
    modal.style.display = 'none';
  }
})();
</script>
</body>
</html>

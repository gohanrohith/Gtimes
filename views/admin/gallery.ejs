<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <link rel="icon" type="image/png" href="/emblem.png">
  <link rel="apple-touch-icon" href="/emblem.png">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="gt-admin">
<%- include('../partials/admin-topbar') %>
<div class="gt-admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="gt-admin-main">
    <div class="gt-admin-page-header">
      <h1>Photo Gallery</h1>
      <a href="/admin/gallery/new" class="btn btn-primary"><i class="fas fa-plus"></i> New Album</a>
    </div>

    <% if (success) { %>
    <div class="gt-alert gt-alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <% if (albums && albums.length > 0) { %>
    <div class="gt-albums-admin-grid">
      <% albums.forEach(album => { %>
      <div class="gt-admin-album-card">
        <div class="gt-admin-album-cover">
          <% if (album.cover_image) { %>
          <img src="/uploads/gallery/<%= album.cover_image %>" alt="<%= album.title %>">
          <% } else { %>
          <div class="gt-album-placeholder-sm"><i class="fas fa-images"></i></div>
          <% } %>
          <span class="gt-album-count-badge"><%= album.photo_count||0 %> photos</span>
        </div>
        <div class="gt-admin-album-info">
          <h4><%= album.title %></h4>
          <% if (album.description) { %><p><%= album.description.substring(0,60) %><%= album.description.length>60?'…':'' %></p><% } %>
          <div style="display:flex;gap:.5rem;margin-top:.75rem;flex-wrap:wrap">
            <a href="/admin/gallery/<%= album.id %>/upload" class="btn btn-xs btn-primary"><i class="fas fa-upload"></i> Upload Photos</a>
            <form action="/admin/gallery/<%= album.id %>/delete" method="POST" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-xs btn-danger gt-confirm-delete"><i class="fas fa-trash"></i> Delete</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="gt-empty" style="margin-top:2rem"><i class="fas fa-images"></i><p>No albums yet. <a href="/admin/gallery/new">Create one</a>.</p></div>
    <% } %>
  </main>
</div>
<script src="/js/admin.js"></script>
</body>
</html>

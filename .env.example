# Copy to .env and fill in values

PORT=3001
NODE_ENV=development

# Database (separate from Greenwood)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gtimes_db
DB_USER=root
DB_PASS=

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Domain config
# Local dev: lvh.me  |  Production: gtimes.in
MAIN_DOMAIN=lvh.me

# Email (Hostinger SMTP)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=news@gtimes.in
MAIL_PASS=
MAIL_FROM=GTimes <news@gtimes.in>

# Persistent uploads directory (set to absolute path OUTSIDE git repo on production)
# Example: UPLOADS_DIR=/home/u821259331/gtimes-uploads
UPLOADS_DIR=

# Greenwood webhook — GTimes will POST to this URL on publish
GREENWOOD_WEBHOOK_URL=https://ghs.ac.in/api/gtimes/sync
GREENWOOD_WEBHOOK_SECRET=change-this-to-match-greenwood-env
